    "zod": "4.3.6"
  },
  "devDependencies": {
    "@ai-cfo/typescript-config": "workspace:*",
    "@types/node": "25.3.5",
    "pino-pretty": "13.1.3",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
