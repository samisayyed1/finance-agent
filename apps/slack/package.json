{
  "name": "slack",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/app.ts",
  "scripts": {
    "dev": "bun --hot run ./src/app.ts",
    "start": "node --import tsx ./src/app.ts",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "test": "NODE_ENV=test vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ai-cfo/database": "workspace:*",
    "@ai-cfo/feedback": "workspace:*",
    "@slack/bolt": "4.7.2",
    "@slack/types": "2.16.0",
    "@slack/web-api": "7.15.2",
    "pino": "10.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@ai-cfo/typescript-config": "workspace:*",
    "@types/node": "25.3.5",
    "pino-pretty": "13.1.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
