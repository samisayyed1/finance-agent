{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Bundler-resolved app (Bun, esbuild, tsx)",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "exclude": ["node_modules", "dist"]
}
