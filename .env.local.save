# AI Operating CFO — root .env.example
#
# Copy to .env.local at the repo root for local dev. Per-app .env.example files
# under apps/* and packages/* exist for next-forge defaults; this file is the
# AI-CFO-specific superset.
#
# Never commit a populated .env file. Secrets are managed in Vercel + Trigger.dev
# + Cloudflare for prod.

# --- Supabase (also pulled by @ai-cfo/supabase + @ai-cfo/database) ---
SUPABASE_URL=https://albmqupqdiajlusvdmgl.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJl
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_URL=
DIRECT_URL=

# --- Clerk (also configured in Clerk Dashboard per CLERK_SUPABASE_SETUP.md) ---
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_JWT_TEMPLATE=supabase

# --- Cloudflare R2 (raw payload immutability) ---
